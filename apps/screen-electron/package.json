{
  "name": "@app/screen-electron",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "dev:renderer": "vite",
    "build": "tsc -b && vite build",
    "electron:start": "electron .",
    "pack:mac": "pnpm run build && electron-builder --mac"
  },
  "dependencies": {
    "@pkg/shared-types": "workspace:*",
    "@pkg/utils": "workspace:*",
    "canvas-confetti": "^1.9.4",
    "gsap": "^3.12.7",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.anniversary.app",
    "productName": "鲸探 Topnod",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/app-icon-512.png"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main/**/*",
      "public/**/*",
      "package.json"
    ]
  },
  "repository": "https://github.com/mochengdx/anniversary2026.git"
}
